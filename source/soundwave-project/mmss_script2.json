            "resolved": [
              "load_scene('GLASS_ORBIT')",
              "set_ui_clarity('minimal')",
              "schedule_transition(to='scene:NOISE_TIDE', duration_ms=360000, curve='exponential')",
              "schedule_ui_evolution(to_clarity='rich', to_theme='AURORA', sync_with_audio=true)"
            ]
          },
          {
            "prompt": "создай дыхание интерфейса вокруг базового состояния, почти незаметное",
            "resolved": [
              "load_group_state('baseline')",
              "start_micro_orbit(center='baseline', radius_audio=0.05, radius_ui=0.03, period_ms=8000)"
            ]
          }
        ],
