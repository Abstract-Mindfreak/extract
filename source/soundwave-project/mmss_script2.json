            "UI_GLOW": "0.6-1.0"
          },
          "warm": {
            "UI_THEME": "WARM_SPECTRUM"
          },
          "cold": {
            "UI_THEME": "COLD_SPECTRUM"
          },
          "monochrome": {
            "UI_THEME": "MONO",
            "COLOR_AMT": "0.1-0.3"
          }
        },
        "macro_examples": [
