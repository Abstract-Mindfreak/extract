          "from": "L1",
          "to": "L2",
          "when": "vision_source_bound"
        },
        {
          "from": "L2",
          "to": "L3",
          "when": "orbit_enabled OR auto_if_session_time>900000"
        },
        {
          "from": "L3",
          "to": "L4",
          "when": "text_intention_received"
        }
      ],
      "auto_save": [
        "on_level_up => save_group_state(as='checkpoint_L{level}')"
      ]
    },
