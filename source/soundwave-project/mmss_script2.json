      {
        "id": "L2",
        "name": "VISION_REACTIVE_METAMOD",
        "scope": [
          "audio",
          "vision_ui"
        ],
        "description": "Мета-мод, где визуальный вход (картинка, камера, vision-поток) модифицирует одновременно параметры синта и визуального интерфейса.", [ppl-ai-file-upload.s3.amazonaws](https://ppl-ai-file-upload.s3.amazonaws.com/web/direct-files/attachments/47217359/d3ad3b67-a043-43f4-a7d0-fc56c11977a8/PrismaticCore.html)
        "triggers": [
          "on_image_drop(area='PRISMATIC_CORE_WINDOW')",
          "on_camera_feed_active()",
          "on_cmd('VISION_METAMOD_ON')"
        ],
        "vision_analysis": {
          "extract": [
            "dominant_palette(5)",
            "brightness_distribution",
            "edge_density",
            "motion_flow",
            "face_or_object_saliency"
          ]
        },
        "mapping_rules_audio": {
          "palette->COLOR_AMT": "COLOR_AMT = norm(saturation_mean)",
          "brightness->DECAY": "DECAY = invert(norm(brightness_mean))",
          "edge_density->DETUNE": "DETUNE = norm(edge_density)",
          "motion_flow->MORPH": "MORPH = norm(global_motion_magnitude)"
        },
        "mapping_rules_ui": {
          "palette->UI_THEME": "pick_theme_by_hue_cluster()",
          "brightness->UI_DEPTH": "UI_DEPTH = norm(brightness_contrast)",
          "edge_density->UI_NOISE": "UI_NOISE = norm(edge_density)",
          "motion_flow->UI_FOCUS_MODE": "switch(SOFT_CENTRIC <-> FLOW_FIELD)",
          "saliency->UI_OVERLAY_DENSITY": "UI_OVERLAY_DENSITY = norm(saliency_spread)"
        },
        "meta_conditions": {
          "if_high_contrast": {
            "audio": {
              "CUTOFF": "push_to(0.75, inertia=0.2)",
              "RES": "push_to(0.8, inertia=0.3)"
            },
            "vision_ui": {
              "UI_GLOW": "push_to(0.9, inertia=0.3)",
              "UI_DEPTH": "push_to(0.8, inertia=0.2)"
            }
          },
          "if_low_contrast": {
            "audio": {
              "CUTOFF": "pull_to(0.35, inertia=0.2)",
              "RES": "pull_to(0.3, inertia=0.3)"
            },
            "vision_ui": {
              "UI_GLOW": "pull_to(0.3, inertia=0.2)",
              "UI_NOISE": "push_to(0.6, inertia=0.3)"
            }
          }
        },
        "ui_feedback": [
          "overlay_text('VISION METAMOD: BOUND', duration=1600)",
          "corner_preview(vision_source, size=96)"
        ]
      },
