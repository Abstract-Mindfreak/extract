            ]
          }
        ],
        "ui_feedback": [
          "top_banner('INTENTION: {short_summary}', fade_out=3000)"
        ]
      }
    ],
    "transitions": {
      "rules": [
        {
          "from": "L0",
          "to": "L1",
          "when": "user_uses_2_plus_scenes OR session_time>300000"
        },
        {
          "from": "L1",
          "to": "L2",
          "when": "first_image_dropped"
        },
        {
          "from": "L2",
          "to": "L3",
          "when": "user_enables_orbit OR auto_if_session_time>900000"
        },
        {
          "from": "L3",
          "to": "L4",
          "when": "text_intention_received"
        }
      ],
      "auto_save": [
        "on_level_up => save_current_state(as='checkpoint_L{level}')"
      ]
    },
    "implementation_notes": {
