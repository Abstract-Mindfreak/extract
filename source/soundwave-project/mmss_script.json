            "COLOR_AMT": "max(0.9-1.0)"
          }
        },
        "macro_examples": [
          {
            "prompt": "сделай переход от стеклянной тишины к шумовой буре за 4 минуты",
            "resolved": [
              "load_scene('GLASS_ORBIT')",
              "schedule_transition(to='scene:NOISE_TIDE', duration_ms=240000, curve='exponential')",
              "gradually_increase(DETUNE, from='scene:GLASS_ORBIT', to='scene:NOISE_TIDE')"
            ]
          },
          {
            "prompt": "микродвижение вокруг базового состояния, как дыхание",
